GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
# Legacy compatibility key name (deprecated): GROP_API_KEY
# GROP_API_KEY=your_groq_api_key_here
LLM_GEMINI_MODEL=gemini-2.5-flash-lite
LLM_GROQ_MODEL=llama-3.3-70b-versatile
LLM_PRIMARY_TIMEOUT_MS=8000
LLM_FALLBACK_TIMEOUT_MS=8000
# Dev/Preview only. Allowed values: timeout | 429 | 503
LLM_TEST_PRIMARY_FAIL=
# Frontend public env (Vite injects these into the browser bundle)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_APP_URL=http://localhost:5173
VITE_ENABLE_DI=true
# Optional frontend API base override (local use only, keep empty by default)
VITE_API_BASE=
# Vite dev proxy target for /api requests
VITE_DEV_API_TARGET=http://localhost:3000
# Local API service port (used by `npm run dev:api`)
API_PORT=3000

# Google Cloud auth (local/offline batch TTS)
# Windows example:
# GOOGLE_APPLICATION_CREDENTIALS=C:\keys\gcp-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# WFD TTS generation defaults (optional overrides)
WFD_TTS_INPUT_FILE=WFD_cleaned_with_wordcount_difficulty.xlsx
WFD_TTS_SHEET_NAME=WFD
WFD_TTS_OUTPUT_DIR=generated-audio
WFD_TTS_SKIP_EXISTING=true
WFD_TTS_OUTPUT_QUESTION_FILE=WFD_with_generated_audio.xlsx
WFD_TTS_REPORT_FILE=tts_generation_report.json
WFD_TTS_LANGUAGE_CODE=en-AU
WFD_TTS_VOICE_NAME=en-AU-Standard-C
WFD_TTS_SSML_GENDER=FEMALE
WFD_TTS_SPEAKING_RATE=0.92
WFD_TTS_PITCH=0
WFD_TTS_AUDIO_ENCODING=MP3

# Server-only env for local Node API / Vercel Functions.
# Never expose these to the frontend and never rename them to VITE_*.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
BREVO_API_KEY=
REGISTER_OTP_FROM_EMAIL=
# Optional. Defaults to "开口"
REGISTER_OTP_FROM_NAME=
WFD_UPLOAD_INPUT_FILE=WFD_with_generated_audio.xlsx
WFD_UPLOAD_SHEET_NAME=WFD
WFD_UPLOAD_AUDIO_DIR=generated-audio
WFD_UPLOAD_BUCKET=question-audio
WFD_UPLOAD_STORAGE_PREFIX=
WFD_UPLOAD_UPSERT=true
WFD_UPLOAD_UPDATE_AUDIO_PATH=false
WFD_UPLOAD_SKIP_MISSING=true
WFD_UPLOAD_OUTPUT_QUESTION_FILE=WFD_with_uploaded_audio.xlsx
WFD_UPLOAD_REPORT_FILE=tts_upload_report.json

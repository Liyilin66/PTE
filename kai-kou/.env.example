# Frontend public env (Vite injects these into the browser bundle)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_APP_URL=http://localhost:5173
VITE_ENABLE_DI=true
# Optional frontend API base override (local use only, keep empty by default)
VITE_API_BASE=
# Vite dev proxy target for /api requests
VITE_DEV_API_TARGET=http://localhost:3000

# Local API service port (used by `npm run dev:api`)
API_PORT=3000

# Server-only env for local Node API / Vercel Functions.
# Never expose these to the frontend and never rename them to VITE_*.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
BREVO_API_KEY=your_brevo_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
REGISTER_OTP_FROM_EMAIL=your_sender_email@example.com
REGISTER_OTP_FROM_NAME=Your App Name

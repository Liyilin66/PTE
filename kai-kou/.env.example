GEMINI_API_KEY=your_gemini_api_key_here
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_APP_URL=http://localhost:5173

# Google Cloud auth (local/offline batch TTS)
# Windows example:
# GOOGLE_APPLICATION_CREDENTIALS=C:\keys\gcp-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# WFD TTS generation defaults (optional overrides)
WFD_TTS_INPUT_FILE=WFD_cleaned_with_wordcount_difficulty.xlsx
WFD_TTS_SHEET_NAME=WFD
WFD_TTS_OUTPUT_DIR=generated-audio
WFD_TTS_SKIP_EXISTING=true
WFD_TTS_OUTPUT_QUESTION_FILE=WFD_with_generated_audio.xlsx
WFD_TTS_REPORT_FILE=tts_generation_report.json
WFD_TTS_LANGUAGE_CODE=en-AU
WFD_TTS_VOICE_NAME=en-AU-Standard-C
WFD_TTS_SSML_GENDER=FEMALE
WFD_TTS_SPEAKING_RATE=0.92
WFD_TTS_PITCH=0
WFD_TTS_AUDIO_ENCODING=MP3

# Supabase upload (optional)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
WFD_UPLOAD_INPUT_FILE=WFD_with_generated_audio.xlsx
WFD_UPLOAD_SHEET_NAME=WFD
WFD_UPLOAD_AUDIO_DIR=generated-audio
WFD_UPLOAD_BUCKET=question-audio
WFD_UPLOAD_STORAGE_PREFIX=
WFD_UPLOAD_UPSERT=true
WFD_UPLOAD_UPDATE_AUDIO_PATH=false
WFD_UPLOAD_SKIP_MISSING=true
WFD_UPLOAD_OUTPUT_QUESTION_FILE=WFD_with_uploaded_audio.xlsx
WFD_UPLOAD_REPORT_FILE=tts_upload_report.json
